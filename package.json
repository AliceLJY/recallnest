{
  "name": "recallnest",
  "version": "1.3.0",
  "description": "RecallNest \u2014 MCP-native, local-first memory search and distillation for AI conversations",
  "license": "MIT",
  "type": "module",
  "bin": {
    "recallnest": "src/cli.ts",
    "memlayer": "src/cli.ts",
    "local-memory": "src/cli.ts"
  },
  "scripts": {
    "search": "bun run src/cli.ts search",
    "ingest": "bun run src/cli.ts ingest",
    "stats": "bun run src/cli.ts stats",
    "mcp": "bun run src/mcp-server.ts",
    "explain": "bun run src/cli.ts explain",
    "distill": "bun run src/cli.ts distill",
    "brief": "bun run src/cli.ts brief",
    "assets": "bun run src/cli.ts assets",
    "clean-briefs": "bun run src/cli.ts clean-briefs --apply",
    "eval": "bun run src/eval.ts",
    "profiles": "bun run src/cli.ts profiles",
    "doctor": "bun run src/cli.ts doctor",
    "demo": "bun run src/cli.ts demo",
    "ui": "bun run src/ui-server.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^12.0.0",
    "openai": "^4.0.0",
    "zod": "^3.25.76"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AliceLJY/recallnest.git"
  },
  "homepage": "https://github.com/AliceLJY/recallnest"
}
